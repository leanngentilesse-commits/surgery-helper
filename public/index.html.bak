<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>术式机器人对标助手</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background-color: #f5f5f5;
            color: #333;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        h1 {
            text-align: center;
            color: #1E4A76;
            margin-bottom: 30px;
            font-size: 28px;
        }
        
        .search-container {
            text-align: center;
            margin-bottom: 30px;
        }
        
        #searchInput {
            width: 400px;
            padding: 12px;
            font-size: 16px;
            border: 2px solid #1E4A76;
            border-radius: 25px;
            outline: none;
        }
        
        #searchBtn {
            padding: 12px 24px;
            font-size: 16px;
            background-color: #1E4A76;
            color: white;
            border: none;
            border-radius: 25px;
            cursor: pointer;
            margin-left: 10px;
        }
        
        #searchBtn:hover {
            background-color: #183B60;
        }
        
        /* 菜单样式 */
        .menu-container {
            margin-top: 30px;
        }
        
        .main-menu {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 20px;
        }
        
        .menu-item {
            background: white;
            border: 2px solid #1E4A76;
            border-radius: 25px;
            padding: 12px 24px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: bold;
            color: #1E4A76;
        }
        
        .menu-item:hover {
            background: #1E4A76;
            color: white;
            transform: translateY(-2px);
        }
        
        .menu-item.active {
            background: #1E4A76;
            color: white;
        }
        
        /* 二级菜单样式 */
        .submenu-container {
            background: white;
            border-radius: 16px;
            padding: 30px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.12);
            margin-top: 30px;
            transition: all 0.3s ease;
        }
        
        .submenu-title {
            color: #1E4A76;
            font-size: 24px;
            margin-bottom: 30px;
            font-weight: bold;
            padding-bottom: 15px;
            border-bottom: 2px solid #E8F0FE;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .submenu-title::before {
            content: ""; 
            display: inline-block;
            width: 4px;
            height: 24px;
            background-color: #1E4A76;
            border-radius: 2px;
        }
        
        .organ-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 24px;
        }
        
        .organ-card {
            background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
            border-radius: 12px;
            padding: 24px;
            border: 1px solid #E2E8F0;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            transition: all 0.3s ease;
        }
        
        .organ-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.12);
            border-color: #1E4A76;
        }
        
        .organ-name {
            font-weight: bold;
            color: #1E4A76;
            margin-bottom: 16px;
            font-size: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .organ-name::before {
            content: "🏥";
            font-size: 16px;
        }
        
        .procedure-list {
            list-style: none;
        }
        
        .procedure-item {
            margin-bottom: 12px;
            padding-left: 20px;
            position: relative;
        }
        
        .procedure-item::before {
            content: "•";
            position: absolute;
            left: 0;
            color: #1E4A76;
            font-weight: bold;
            font-size: 18px;
        }
        
        .procedure-link {
            color: #0F766E;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 14px;
            display: inline-block;
            padding: 4px 8px;
            border-radius: 4px;
        }
        
        .procedure-link:hover {
            color: white;
            background-color: #1E4A76;
            transform: translateX(4px);
        }
        
        /* 空状态 */
        .empty-state {
            text-align: center;
            padding: 80px 20px;
            color: #666;
            background: white;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.12);
            margin-top: 30px;
        }
        
        .empty-state h3 {
            color: #1E4A76;
            margin-bottom: 15px;
            font-size: 20px;
        }
        
        .empty-state p {
            font-size: 16px;
            line-height: 1.5;
        }
        
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.5);
        }
        
        .modal-content {
            background-color: white;
            margin: 5% auto;
            padding: 30px;
            border-radius: 12px;
            width: 80%;
            max-width: 1000px;
            max-height: 80vh;
            overflow-y: auto;
        }
        
        .close {
            color: #aaa;
            float: right;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }
        
        .close:hover {
            color: black;
        }
        
        .procedure-header {
            margin-bottom: 30px;
        }
        
        .procedure-header h2 {
            color: #1E4A76;
            margin-bottom: 10px;
        }
        
        .procedure-header p {
            color: #666;
            margin-bottom: 5px;
        }
        
        .section {
            margin-bottom: 30px;
        }
        
        .section h3 {
            color: #1E4A76;
            margin-bottom: 15px;
            font-size: 18px;
        }
        
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 15px;
            margin-top: 15px;
        }
        
        .metric-card {
            background: #f9f9f9;
            padding: 15px;
            border-radius: 8px;
            border-left: 4px solid #1E4A76;
        }
        
        .metric-name {
            font-weight: bold;
            margin-bottom: 5px;
        }
        
        .metric-value {
            color: #1E4A76;
            font-size: 18px;
            margin-bottom: 5px;
        }
        
        .metric-desc {
            font-size: 12px;
            color: #666;
        }
        
        .video-container {
            display: flex;
            gap: 20px;
            margin-top: 20px;
        }
        
        .video-section {
            flex: 1;
        }
        
        .video-section h4 {
            margin-bottom: 10px;
            color: #333;
        }
        
        .video-wrapper {
            position: relative;
            padding-bottom: 56.25%;
            height: 0;
            overflow: hidden;
            border-radius: 8px;
        }
        
        .video-wrapper iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
        }
        
        .video-controls {
            margin-top: 15px;
            display: flex;
            gap: 10px;
        }
        
        .video-btn {
            padding: 8px 16px;
            background-color: #1E4A76;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        
        .video-btn:hover {
            background-color: #183B60;
        }
        
        .timeline {
            margin-top: 20px;
        }
        
        .timeline-item {
            display: flex;
            margin-bottom: 10px;
        }
        
        .timeline-time {
            width: 80px;
            font-weight: bold;
            color: #1E4A76;
        }
        
        .timeline-action {
            flex: 1;
        }
        
        .competitors-list {
            margin-top: 15px;
        }
        
        .competitor-card {
            background: #f9f9f9;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 15px;
            border-left: 4px solid #1E4A76;
        }
        
        .competitor-brand {
            font-weight: bold;
            color: #1E4A76;
            margin-bottom: 5px;
        }
        
        .competitor-model {
            font-weight: bold;
            margin-bottom: 10px;
        }
        
        .competitor-info {
            margin-bottom: 5px;
        }
        
        .search-results {
            margin-top: 30px;
        }
        
        .search-results h3 {
            color: #1E4A76;
            margin-bottom: 15px;
        }
        
        .result-item {
            background: white;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 10px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        
        .result-type {
            font-size: 12px;
            color: #666;
            margin-bottom: 5px;
        }
        
        .result-name {
            font-weight: bold;
            color: #1E4A76;
            cursor: pointer;
        }
        
        .result-name:hover {
            text-decoration: underline;
        }
        
        /* 登录模态框 */
        #loginModal {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        #loginModal .modal-content {
            background: white;
            border-radius: 20px;
            padding: 40px;
            width: 400px;
            max-width: 90%;
            text-align: center;
        }
        
        #loginModal h2 {
            text-align: center;
            margin-bottom: 30px;
            color: #1E4A76;
        }
        
        #loginModal label {
            display: block;
            text-align: left;
            margin-bottom: 8px;
            font-weight: bold;
            color: #333;
        }
        
        #loginModal input {
            width: 100%;
            padding: 12px;
            border: 2px solid #ddd;
            border-radius: 8px;
            font-size: 16px;
            margin-bottom: 20px;
        }
        
        #loginModal input:focus {
            outline: none;
            border-color: #1E4A76;
        }
        
        #loginBtn {
            width: 100%;
            padding: 12px;
            background-color: #1E4A76;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            margin-bottom: 20px;
        }
        
        #loginBtn:hover {
            background-color: #183B60;
        }
        
        #loginError {
            display: none;
            color: red;
            margin-top: 10px;
        }
        
        /* 响应式设计 */
        @media (max-width: 768px) {
            .container {
                padding: 10px;
            }
            
            h1 {
                font-size: 24px;
            }
            
            #searchInput {
                width: 250px;
            }
            
            .main-menu {
                flex-direction: column;
                align-items: stretch;
            }
            
            .menu-item {
                text-align: center;
            }
            
            .submenu-container {
                padding: 20px;
                margin-top: 20px;
            }
            
            .submenu-title {
                font-size: 20px;
                margin-bottom: 20px;
            }
            
            .organ-grid {
                grid-template-columns: 1fr;
                gap: 16px;
            }
            
            .organ-card {
                padding: 20px;
            }
            
            .organ-name {
                font-size: 16px;
            }
            
            .empty-state {
                padding: 60px 20px;
                margin-top: 20px;
            }
            
            .empty-state h3 {
                font-size: 18px;
            }
            
            .empty-state p {
                font-size: 14px;
            }
            
            .video-container {
                flex-direction: column;
            }
            
            .modal-content {
                width: 95%;
                margin: 10% auto;
                padding: 20px;
            }
            
            #loginModal .modal-content {
                padding: 30px;
            }
        }
    </style>
</head>
<body>
    <!-- 登录模态框 -->
    <div id="loginModal">
        <div class="modal-content">
            <h2>登录系统</h2>
            <div style="margin-bottom: 20px;">
                <label>用户名</label>
                <input type="text" id="loginUsername" placeholder="请输入用户名">
            </div>
            <div style="margin-bottom: 30px;">
                <label>密码</label>
                <input type="password" id="loginPassword" placeholder="请输入密码">
            </div>
            <button id="loginBtn">登录</button>
            <div id="loginError" style="display: none;">用户名或密码错误</div>
        </div>
    </div>
    
    <!-- 主界面 -->
    <div class="container" id="mainContent" style="display: none;">
        <h1>术式机器人对标助手</h1>
        
        <div class="search-container">
            <input type="text" id="searchInput" placeholder="搜索科室或术式...">
            <button id="searchBtn">搜索</button>
        </div>
        
        <div id="searchResults" class="search-results" style="display: none;"></div>
        
        <div class="menu-container">
            <div class="main-menu" id="mainMenu"></div>
            <div class="submenu-container" id="submenuContainer" style="display: none;">
                <h2 class="submenu-title" id="submenuTitle"></h2>
                <div class="organ-grid" id="organGrid"></div>
            </div>
            <div class="empty-state" id="emptyState">
                <h3>请选择一个科室</h3>
                <p>从上方菜单中选择科室，查看对应的术式分类</p>
            </div>
        </div>
    </div>
    
    <!-- 术式详情全屏界面 -->
    <div id="procedurePage" style="display: none; min-height: 100vh; background-color: #f5f5f5;">
        <div class="container" style="max-width: 1400px; padding: 30px;">
            <!-- 顶部导航 -->
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 40px;">
                <button id="backBtn" style="background: #1E4A76; color: white; border: none; padding: 12px 24px; border-radius: 8px; cursor: pointer; font-size: 16px; display: flex; align-items: center; gap: 8px;">
                    ← 返回科室选择
                </button>
                <h1 style="color: #1E4A76; font-size: 32px; margin: 0;">术式详情</h1>
                <div style="width: 150px;"></div> <!-- 占位，保持标题居中 -->
            </div>
            
            <!-- 术式信息 -->
            <div class="procedure-header" style="background: white; border-radius: 16px; padding: 40px; box-shadow: 0 4px 20px rgba(0,0,0,0.12); margin-bottom: 30px;">
                <h2 id="procedureName" style="color: #1E4A76; font-size: 28px; margin-bottom: 15px;"></h2>
                <div style="display: flex; gap: 30px; margin-bottom: 20px;">
                    <p id="procedureDept" style="color: #666; font-size: 16px; margin: 0;"></p>
                    <p id="procedureOrgan" style="color: #666; font-size: 16px; margin: 0;"></p>
                </div>
            </div>
            
            <!-- 内容网格 -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-bottom: 30px;">
                <!-- 左侧列 -->
                <div>
                    <!-- 适应症 -->
                    <div class="section" style="background: white; border-radius: 16px; padding: 30px; box-shadow: 0 4px 20px rgba(0,0,0,0.12); margin-bottom: 30px;">
                        <h3 style="color: #1E4A76; font-size: 20px; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid #E8F0FE;">适应症</h3>
                        <p id="procedureIndications" style="line-height: 1.6; color: #333;"></p>
                    </div>
                    
                    <!-- 禁忌症 -->
                    <div class="section" style="background: white; border-radius: 16px; padding: 30px; box-shadow: 0 4px 20px rgba(0,0,0,0.12); margin-bottom: 30px;">
                        <h3 style="color: #1E4A76; font-size: 20px; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid #E8F0FE;">禁忌症</h3>
                        <p id="procedureContraindications" style="line-height: 1.6; color: #333;"></p>
                    </div>
                    
                    <!-- 指南差异 -->
                    <div class="section" style="background: white; border-radius: 16px; padding: 30px; box-shadow: 0 4px 20px rgba(0,0,0,0.12); margin-bottom: 30px;">
                        <h3 style="color: #1E4A76; font-size: 20px; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid #E8F0FE;">指南差异</h3>
                        <p id="guidelineDiff" style="line-height: 1.6; color: #333;"></p>
                    </div>
                </div>
                
                <!-- 右侧列 -->
                <div>
                    <!-- 临床指标 -->
                    <div class="section" style="background: white; border-radius: 16px; padding: 30px; box-shadow: 0 4px 20px rgba(0,0,0,0.12); margin-bottom: 30px;">
                        <h3 style="color: #1E4A76; font-size: 20px; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid #E8F0FE;">临床指标</h3>
                        <div class="metrics-grid" id="clinicalMetrics" style="display: grid; grid-template-columns: 1fr; gap: 15px;"></div>
                    </div>
                    
                    <!-- 手术指标 -->
                    <div class="section" style="background: white; border-radius: 16px; padding: 30px; box-shadow: 0 4px 20px rgba(0,0,0,0.12); margin-bottom: 30px;">
                        <h3 style="color: #1E4A76; font-size: 20px; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid #E8F0FE;">手术指标</h3>
                        <div class="metrics-grid" id="operationMetrics" style="display: grid; grid-template-columns: 1fr; gap: 15px;"></div>
                    </div>
                </div>
            </div>
            
            <!-- 手术步骤 -->
            <div class="section" style="background: white; border-radius: 16px; padding: 30px; box-shadow: 0 4px 20px rgba(0,0,0,0.12); margin-bottom: 30px;">
                <h3 style="color: #1E4A76; font-size: 20px; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid #E8F0FE;">手术步骤</h3>
                <div class="timeline" id="procedureSteps" style="margin-top: 20px;"></div>
            </div>
            
            <!-- 手术视频 -->
            <div class="section" style="background: white; border-radius: 16px; padding: 30px; box-shadow: 0 4px 20px rgba(0,0,0,0.12); margin-bottom: 30px;">
                <h3 style="color: #1E4A76; font-size: 20px; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid #E8F0FE;">手术视频</h3>
                <div class="video-container" style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 20px;">
                    <div class="video-section">
                        <h4 style="margin-bottom: 15px; color: #333; font-size: 16px;">传统手术</h4>
                        <div class="video-wrapper" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 12px; margin-bottom: 15px;">
                            <iframe id="traditionalVideo" frameborder="0" allowfullscreen style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none;"></iframe>
                        </div>
                        <div class="video-controls" style="display: flex; gap: 10px;">
                            <button class="video-btn" onclick="seekToTime('traditionalVideo', 0)" style="padding: 8px 16px; background-color: #1E4A76; color: white; border: none; border-radius: 4px; cursor: pointer;">开始</button>
                            <button class="video-btn" onclick="seekToTime('traditionalVideo', 30)" style="padding: 8px 16px; background-color: #1E4A76; color: white; border: none; border-radius: 4px; cursor: pointer;">30秒</button>
                            <button class="video-btn" onclick="seekToTime('traditionalVideo', 60)" style="padding: 8px 16px; background-color: #1E4A76; color: white; border: none; border-radius: 4px; cursor: pointer;">1分钟</button>
                        </div>
                    </div>
                    <div class="video-section">
                        <h4 style="margin-bottom: 15px; color: #333; font-size: 16px;">机器人手术</h4>
                        <div class="video-wrapper" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 12px; margin-bottom: 15px;">
                            <iframe id="roboticVideo" frameborder="0" allowfullscreen style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none;"></iframe>
                        </div>
                        <div class="video-controls" style="display: flex; gap: 10px;">
                            <button class="video-btn" onclick="seekToTime('roboticVideo', 0)" style="padding: 8px 16px; background-color: #1E4A76; color: white; border: none; border-radius: 4px; cursor: pointer;">开始</button>
                            <button class="video-btn" onclick="seekToTime('roboticVideo', 30)" style="padding: 8px 16px; background-color: #1E4A76; color: white; border: none; border-radius: 4px; cursor: pointer;">30秒</button>
                            <button class="video-btn" onclick="seekToTime('roboticVideo', 60)" style="padding: 8px 16px; background-color: #1E4A76; color: white; border: none; border-radius: 4px; cursor: pointer;">1分钟</button>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- 竞品分析 -->
            <div class="section" style="background: white; border-radius: 16px; padding: 30px; box-shadow: 0 4px 20px rgba(0,0,0,0.12); margin-bottom: 30px;">
                <h3 style="color: #1E4A76; font-size: 20px; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid #E8F0FE;">竞品分析</h3>
                <div class="competitors-list" id="competitorsList" style="margin-top: 20px;"></div>
            </div>
        </div>
    </div>
    
    <script>
        let isLoggedIn = false;
        
        // 登录逻辑
        function initLogin() {
            const loginBtn = document.getElementById('loginBtn');
            const loginModal = document.getElementById('loginModal');
            const mainContent = document.getElementById('mainContent');
            const loginError = document.getElementById('loginError');
            
            loginBtn.addEventListener('click', function() {
                const username = document.getElementById('loginUsername').value;
                const password = document.getElementById('loginPassword').value;
                
                // 验证登录信息
                if (username === 'admin' && password === '123') {
                    isLoggedIn = true;
                    loginModal.style.display = 'none';
                    mainContent.style.display = 'block';
                    loadDepartments();
                } else {
                    loginError.style.display = 'block';
                }
            });
        }
        
        // 加载科室数据 - 创建主菜单
        function loadDepartments() {
            fetch('/api/departments')
                .then(response => response.json())
                .then(data => {
                    const mainMenu = document.getElementById('mainMenu');
                    mainMenu.innerHTML = '';
                    
                    data.forEach(department => {
                        const menuItem = document.createElement('div');
                        menuItem.className = 'menu-item';
                        menuItem.textContent = department.name;
                        menuItem.dataset.id = department.id;
                        menuItem.dataset.name = department.name;
                        menuItem.dataset.organs = JSON.stringify(department.organs);
                        
                        menuItem.addEventListener('click', function() {
                            // 移除所有菜单项的active类
                            document.querySelectorAll('.menu-item').forEach(item => {
                                item.classList.remove('active');
                            });
                            // 添加当前菜单项的active类
                            this.classList.add('active');
                            // 显示二级菜单
                            showSubmenu(department);
                        });
                        
                        mainMenu.appendChild(menuItem);
                    });
                })
                .catch(error => {
                    console.error('Error loading departments:', error);
                });
        }
        
        // 显示二级菜单
        function showSubmenu(department) {
            const submenuContainer = document.getElementById('submenuContainer');
            const submenuTitle = document.getElementById('submenuTitle');
            const organGrid = document.getElementById('organGrid');
            const emptyState = document.getElementById('emptyState');
            
            // 隐藏空状态，显示二级菜单
            emptyState.style.display = 'none';
            submenuContainer.style.display = 'block';
            
            // 设置标题
            submenuTitle.textContent = `${department.name} - 术式分类`;
            
            // 清空器官网格
            organGrid.innerHTML = '';
            
            // 添加器官卡片
            department.organs.forEach(organ => {
                const organCard = document.createElement('div');
                organCard.className = 'organ-card';
                
                organCard.innerHTML = `
                    <div class="organ-name">${organ.name}</div>
                    <ul class="procedure-list">
                        ${organ.procedures.map(procedure => `
                            <li class="procedure-item">
                                <span class="procedure-link" onclick="loadProcedure('${procedure}')">${procedure}</span>
                            </li>
                        `).join('')}
                    </ul>
                `;
                
                organGrid.appendChild(organCard);
            });
        }
        
        // 加载术式详情
        function loadProcedure(procedureName) {
            fetch(`/api/procedures/${encodeURIComponent(procedureName)}`)
                .then(response => response.json())
                .then(data => {
                    // 填充术式信息
                    document.getElementById('procedureName').textContent = data.name;
                    document.getElementById('procedureDept').textContent = `科室: ${data.dept}`;
                    document.getElementById('procedureOrgan').textContent = `器官: ${data.organ}`;
                    document.getElementById('procedureIndications').textContent = data.indications;
                    document.getElementById('procedureContraindications').textContent = data.contraindications;
                    document.getElementById('guidelineDiff').textContent = data.guidelineDiff;
                    
                    // 填充临床指标
                    const clinicalMetrics = document.getElementById('clinicalMetrics');
                    clinicalMetrics.innerHTML = '';
                    data.clinicalMetrics.forEach(metric => {
                        const metricCard = document.createElement('div');
                        metricCard.style = 'background: #f9f9f9; padding: 20px; border-radius: 12px; border-left: 4px solid #1E4A76; margin-bottom: 15px;';
                        metricCard.innerHTML = `
                            <div style="font-weight: bold; margin-bottom: 8px; color: #333;">${metric.name}</div>
                            <div style="color: #1E4A76; font-size: 18px; margin-bottom: 8px;">${metric.value}</div>
                            <div style="font-size: 14px; color: #666;">${metric.desc}</div>
                        `;
                        clinicalMetrics.appendChild(metricCard);
                    });
                    
                    // 填充手术指标
                    const operationMetrics = document.getElementById('operationMetrics');
                    operationMetrics.innerHTML = '';
                    data.operationMetrics.forEach(metric => {
                        const metricCard = document.createElement('div');
                        metricCard.style = 'background: #f9f9f9; padding: 20px; border-radius: 12px; border-left: 4px solid #1E4A76; margin-bottom: 15px;';
                        metricCard.innerHTML = `
                            <div style="font-weight: bold; margin-bottom: 8px; color: #333;">${metric.name}</div>
                            <div style="color: #1E4A76; font-size: 18px; margin-bottom: 8px;">${metric.value}</div>
                            <div style="font-size: 14px; color: #666;">${metric.desc}</div>
                        `;
                        operationMetrics.appendChild(metricCard);
                    });
                    
                    // 填充手术步骤
                    const procedureSteps = document.getElementById('procedureSteps');
                    procedureSteps.innerHTML = '';
                    data.steps.forEach(step => {
                        const stepItem = document.createElement('div');
                        stepItem.style = 'display: flex; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid #E2E8F0;';
                        stepItem.innerHTML = `
                            <div style="width: 100px; font-weight: bold; color: #1E4A76; font-size: 16px;">${step.timestamp}s</div>
                            <div style="flex: 1; font-size: 16px; color: #333;">${step.name}</div>
                        `;
                        procedureSteps.appendChild(stepItem);
                    });
                    
                    // 设置视频源
                    document.getElementById('traditionalVideo').src = getVideoUrl(data.traditionalVideo);
                    document.getElementById('roboticVideo').src = getVideoUrl(data.roboticVideo);
                    
                    // 加载竞品数据
                    loadCompetitors(procedureName);
                    
                    // 隐藏主界面，显示术式详情界面
                    document.getElementById('mainContent').style.display = 'none';
                    document.getElementById('procedurePage').style.display = 'block';
                })
                .catch(error => {
                    console.error('Error loading procedure:', error);
                });
        }
        
        // 加载竞品数据
        function loadCompetitors(procedureName) {
            fetch(`/api/competitors/${encodeURIComponent(procedureName)}`)
                .then(response => response.json())
                .then(data => {
                    const competitorsList = document.getElementById('competitorsList');
                    competitorsList.innerHTML = '';
                    
                    data.forEach(competitor => {
                        const competitorCard = document.createElement('div');
                        competitorCard.style = 'background: #f9f9f9; padding: 25px; border-radius: 12px; margin-bottom: 20px; border-left: 4px solid #1E4A76;';
                        competitorCard.innerHTML = `
                            <div style="font-weight: bold; color: #1E4A76; margin-bottom: 8px; font-size: 18px;">${competitor.brand}</div>
                            <div style="font-weight: bold; margin-bottom: 15px; font-size: 16px;">${competitor.model}</div>
                            <div style="margin-bottom: 8px; font-size: 14px;"><strong>参数:</strong> ${competitor.params}</div>
                            <div style="margin-bottom: 8px; font-size: 14px;"><strong>平均价格:</strong> ${competitor.priceAvg}</div>
                            <div style="margin-bottom: 8px; font-size: 14px;"><strong>装机量:</strong> ${competitor.installs}</div>
                            <div style="margin-bottom: 8px; font-size: 14px;"><strong>优势:</strong> ${competitor.advantage}</div>
                            <div style="font-size: 14px; color: #666;"><strong>数据来源:</strong> ${competitor.source}</div>
                        `;
                        competitorsList.appendChild(competitorCard);
                    });
                })
                .catch(error => {
                    console.error('Error loading competitors:', error);
                });
        }
        
        // 搜索功能
        function initSearch() {
            const searchBtn = document.getElementById('searchBtn');
            const searchInput = document.getElementById('searchInput');
            const searchResults = document.getElementById('searchResults');
            
            searchBtn.addEventListener('click', function() {
                const keyword = searchInput.value.trim();
                if (keyword) {
                    fetch(`/api/search?keyword=${encodeURIComponent(keyword)}`)
                        .then(response => response.json())
                        .then(data => {
                            searchResults.innerHTML = '';
                            searchResults.style.display = 'block';
                            
                            if (data.departments.length === 0 && data.procedures.length === 0) {
                                searchResults.innerHTML = '<p>未找到相关结果</p>';
                                return;
                            }
                            
                            data.departments.forEach(dept => {
                                const resultItem = document.createElement('div');
                                resultItem.className = 'result-item';
                                resultItem.innerHTML = `
                                    <div class="result-type">${dept.type}</div>
                                    <div class="result-name" onclick="loadDepartment('${dept.id}')">${dept.name}</div>
                                `;
                                searchResults.appendChild(resultItem);
                            });
                            
                            data.procedures.forEach(proc => {
                                const resultItem = document.createElement('div');
                                resultItem.className = 'result-item';
                                resultItem.innerHTML = `
                                    <div class="result-type">${proc.type}</div>
                                    <div class="result-name" onclick="loadProcedure('${proc.name}')">${proc.name}</div>
                                `;
                                searchResults.appendChild(resultItem);
                            });
                        })
                        .catch(error => {
                            console.error('Error searching:', error);
                        });
                }
            });
            
            // 回车键搜索
            searchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    searchBtn.click();
                }
            });
        }
        
        // 加载科室详情
        function loadDepartment(deptId) {
            fetch(`/api/departments/${deptId}`)
                .then(response => response.json())
                .then(data => {
                    // 移除所有菜单项的active类
                    document.querySelectorAll('.menu-item').forEach(item => {
                        item.classList.remove('active');
                    });
                    // 激活对应的菜单项
                    const menuItem = document.querySelector(`.menu-item[data-id="${deptId}"]`);
                    if (menuItem) {
                        menuItem.classList.add('active');
                    }
                    // 显示二级菜单
                    showSubmenu(data);
                    // 隐藏搜索结果
                    document.getElementById('searchResults').style.display = 'none';
                })
                .catch(error => {
                    console.error('Error loading department:', error);
                });
        }
        
        // 视频控制
        function seekToTime(videoId, seconds) {
            alert('视频控制功能在iframe中可能受限，建议直接在视频播放器中操作。');
        }
        
